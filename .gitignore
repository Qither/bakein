# Dependencies
**/node_modules/
.pnp
.pnp.*

# Yarn Berry metadata: keep reproducible project assets, ignore local caches.
.yarn/*
!.yarn/patches/
!.yarn/plugins/
!.yarn/releases/
!.yarn/sdks/
!.yarn/versions/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment and local secrets
.env
.env.*
!.env.example
!.env.*.example
*.local

# Taro / frontend build outputs
bakein.app/dist/
bakein.app/deploy_versions/
bakein.app/.temp/
bakein.app/.rn_temp/
bakein.app/.swc/
bakein.app/.cache/
bakein.app/.taro/
bakein.app/.eslintcache
bakein.app/.stylelintcache
bakein.app/project.private.config.json

# .NET / Visual Studio build outputs
**/[Bb]in/
**/[Oo]bj/
**/.vs/
**/TestResults/
**/BenchmarkDotNet.Artifacts/
**/*.user
**/*.suo
**/*.rsuser
**/*.userosscache
**/*.sln.docstates
**/*.nupkg
**/*.snupkg

# Coverage and test artifacts
coverage/
**/coverage/
**/coverage.cobertura.xml
**/*.coverage
**/*.coveragexml
**/lcov.info
**/.nyc_output/

# Logs and temporary files
logs/
*.log
*.tmp
*.temp
*.bak

# OS and editor noise
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.swp
*.swo
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json

# Local Codex / OMX runtime state
.codex/hooks.json
.codex/cache/
.codex/logs/
.codex/tmp/
.omx/cache/
.omx/logs/
.omx/state/
.omx/*.json

# Graphify generated caches; keep top-level graph artifacts visible.
**/graphify-out/
